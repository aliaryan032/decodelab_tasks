def main():
    
    my_tasks = []
    
    # Track the ID number for each task
    task_id_counter = 1

    print("=== WELCOME TO THE DECODELABS TO-DO SYSTEM ===")

    # The Process Loop (Keeps the program running until we choose to quit)
    while True:
        print("\n--- MENU ---")
        print("1. Add a New Task")
        print("2. View All Tasks")
        print("3. Exit Program")
        
        choice = input("Select an option (1-3): ")

        # --- OPTION 1: ADD DATA ---
        if choice == "1":
            task_name = input("Enter the task description: ")
            
            # Create a dictionary (a database row) for the task
            task_entry = {
                "id": task_id_counter,
                "task": task_name
            }
            
            # Append the dictionary to our list
            my_tasks.append(task_entry)
            print(f"Success! Added task ID {task_id_counter}: '{task_name}'")
            
            # Increase the ID counter for the next task
            task_id_counter += 1

        # --- OPTION 2: VIEW DATA ---
        elif choice == "2":
            if not my_tasks:
                print("Your To-Do List is currently empty!")
            else:
                print("\n--- YOUR TO-DO LIST ---")
               
                for index, task_entry in enumerate(my_tasks, start=1):
                    print(f"{index}. [ID: {task_entry['id']}] -> {task_entry['task']}")

        # --- OPTION 3: EXIT ---
        elif choice == "3":
            print("Thank you for using the DecodeLabs system. Goodbye!")
            break
            
        else:
            print("Invalid choice! Please type 1, 2, or 3.")


if __name__ == "__main__":
    main()
